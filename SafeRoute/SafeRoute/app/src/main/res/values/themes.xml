<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SafeRoute" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/primary_blue</item>
        <item name="android:navigationBarColor">@color/background_light</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.SafeRoute.Dark" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@color/primary_blue_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.SafeRoute.Splash" parent="Theme.SafeRoute">
        <item name="android:windowBackground">@color/primary_blue</item>
        <item name="android:statusBarColor">@color/primary_blue</item>
    </style>
</resources>
